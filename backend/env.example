# 複製這個檔案為 .env，填入實際的值
# .env 已在 .gitignore 中，不會被 commit

# MongoDB Atlas 連線字串
# 格式：mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/

# 資料庫名稱
DB_NAME=course_system

# 前端 URL（開發時填 localhost，部署後填 Vercel URL）
FRONTEND_URL=http://localhost:5173

# 後端 port（macOS 常有系統服務佔用 5000，開發建議用 5001）
PORT=5001

# 環境設定（development / production）
FLASK_ENV=development

# JWT 簽章密鑰（正式環境必須設定為高強度隨機值）
JWT_SECRET=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=1
